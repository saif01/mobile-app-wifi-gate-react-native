# Copy this file to android/keystore.properties (do not commit).
# storeFile is relative to the android/app/ module (put the .jks next to build.gradle there).
# Use UTF-8 without BOM. If Gradle says "Cannot convert null to File", the file has a BOM or wrong keys.
#
# For a truly NEW Play app only, you may generate a new upload keystore:
#   powershell -File scripts/create-play-keystore.ps1 -StorePassword "YOUR_STORE_PASS" -KeyPassword "YOUR_KEY_PASS"
# Do not do this for an existing Play package unless Google has already reset the upload key.
#
# Docs: https://reactnative.dev/docs/signed-apk-android
#
# Wrong key / fingerprint mismatch (Play: "signed with the wrong key"):
# Play expects the SAME upload certificate you used for the first upload (or the one
# registered under Play Console > your app > Release > Setup > App integrity / App signing).
# A NEW keystore (e.g. from create-play-keystore.ps1) will NOT match — you must sign with
# the original .jks (e.g. from EAS credentials download, your backup, or your team).
# Verify before upload:
#   powershell -File scripts/show-keystore-sha1.ps1
# If you lost the key, use Play Console "Request upload key reset" (policy permitting).

storeFile=upload-keystore.jks
storePassword=your-store-password
keyAlias=upload
keyPassword=your-key-password
